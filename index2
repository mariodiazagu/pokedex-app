/* LOADING */
#loading{ position:fixed; inset:0; background:var(--bg); display:flex; flex-direction:column; align-items:center; justify-content:center; z-index:2000; padding:32px; padding-top:calc(32px + var(--safe-top)); text-align:center; }
#loading.hidden{ display:none; }
.ld-ball{ font-size:72px; margin-bottom:16px; animation:spin 3s linear infinite; }
@keyframes spin{ to{ transform:rotate(360deg); } }
.ld-title{ font-size:34px; font-weight:900; letter-spacing:-.5px; margin-bottom:4px; }
.ld-sub{ color:var(--text2); font-size:14px; font-weight:700; margin-bottom:32px; }
.bar-wrap{ width:100%; height:12px; background:var(--border); border-radius:6px; overflow:hidden; margin-bottom:8px; }
.bar-fill{ height:100%; background:linear-gradient(90deg,var(--accent),var(--gold)); border-radius:6px; transition:width .4s; width:0%; }
.bar-pct{ font-size:20px; font-weight:900; margin-bottom:10px; }
.ld-hint{ color:var(--text2); font-size:13px; font-weight:700; margin-bottom:6px; }
.ld-note{ color:var(--text3); font-size:11px; font-weight:700; }
.ld-error{ color:var(--accent); font-size:14px; font-weight:800; margin-top:16px; display:none; }
.ld-retry{ margin-top:12px; padding:12px 28px; background:var(--accent); border:none; border-radius:12px; color:#fff; font-size:15px; font-weight:800; cursor:pointer; font-family:var(--font); display:none; }

/* APP */
#app{ display:none; flex-direction:column; height:100dvh; }
#app.visible{ display:flex; }

/* HEADER */
.app-header{ padding:calc(10px + var(--safe-top)) 16px 10px; display:flex; justify-content:space-between; align-items:center; flex-shrink:0; border-bottom:1px solid var(--border); }
.app-title{ font-size:24px; font-weight:900; letter-spacing:-.5px; }
.app-stats{ font-size:11px; color:var(--text2); font-weight:700; margin-top:1px; }
.hdr-btn{ width:38px; height:38px; background:var(--card); border-radius:11px; border:1.5px solid var(--border); display:flex; align-items:center; justify-content:center; font-size:17px; cursor:pointer; }

/* TAB BAR */
.tab-bar{ flex-shrink:0; display:flex; border-top:1px solid var(--border); background:var(--card); padding-bottom:var(--safe-bottom); }
.tab-btn{ flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:9px 4px 7px; cursor:pointer; gap:3px; border:none; background:none; font-family:var(--font); }
.tab-icon{ font-size:19px; line-height:1; }
.tab-label{ font-size:9px; font-weight:800; color:var(--text3); text-transform:uppercase; letter-spacing:.3px; }
.tab-btn.active .tab-label{ color:var(--accent); }

/* PAGES */
.page{ display:none; flex-direction:column; flex:1; overflow:hidden; min-height:0; }
.page.active{ display:flex; }

/* SEARCH */
.search-wrap{ padding:10px 16px 6px; flex-shrink:0; }
.search-box{ display:flex; align-items:center; background:var(--card); border-radius:14px; padding:11px 14px; gap:10px; border:1.5px solid var(--border); }
.search-input{ flex:1; background:none; border:none; outline:none; color:var(--text); font-size:16px; font-family:var(--font); font-weight:700; }
.search-input::placeholder{ color:var(--text3); font-weight:700; }
.s-clear{ color:var(--text2); cursor:pointer; font-size:14px; padding:4px; display:none; }
.s-clear.show{ display:block; }

/* FILTER ROWS */
.frow{ overflow-x:auto; padding:0 16px 6px; flex-shrink:0; scrollbar-width:none; -webkit-overflow-scrolling:touch; }
.frow::-webkit-scrollbar{ display:none; }
.frow-inner{ display:flex; gap:6px; white-space:nowrap; }
.chip{ display:inline-flex; align-items:center; padding:6px 12px; border-radius:20px; background:var(--card); border:1.5px solid var(--border); color:var(--text2); font-size:12px; font-weight:800; cursor:pointer; white-space:nowrap; font-family:var(--font); }
.chip.on{ background:var(--accent); border-color:var(--accent); color:#fff; }
.rchip{ display:inline-flex; align-items:center; gap:4px; padding:6px 12px; border-radius:20px; font-size:12px; font-weight:800; cursor:pointer; white-space:nowrap; font-family:var(--font); border:1.5px solid; }
.results-info{ padding:0 16px 4px; color:var(--text3); font-size:11px; flex-shrink:0; font-weight:800; }

/* GRID */
.grid-scroll{ flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch; padding:0 10px; padding-bottom:calc(8px + var(--safe-bottom)); overscroll-behavior:contain; }
.poke-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:8px; }

.poke-card{ background:var(--card); border-radius:14px; padding:8px 6px 8px; display:flex; flex-direction:column; align-items:center; border:1.5px solid var(--border); cursor:pointer; transition:transform .12s; min-height:122px; position:relative; overflow:hidden; }
.poke-card:active{ transform:scale(.93); }
.card-top{ display:flex; justify-content:space-between; align-items:center; width:100%; margin-bottom:1px; }
.card-num{ font-size:9px; color:var(--text3); font-weight:800; }
.card-rar{ font-size:10px; line-height:1; }
.poke-img{ width:62px; height:62px; object-fit:contain; }
.poke-img.px{ width:54px; height:54px; image-rendering:pixelated; margin:4px; }
.poke-name{ font-size:10px; font-weight:800; text-align:center; margin:3px 0 2px; width:100%; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.poke-types{ display:flex; gap:3px; flex-wrap:wrap; justify-content:center; }
.type-tag{ padding:2px 5px; border-radius:5px; font-size:8px; font-weight:800; color:#fff; }
.card-badges{ position:absolute; bottom:5px; right:5px; display:flex; gap:1px; font-size:10px; }
.card-top-right{ position:absolute; top:5px; right:5px; display:flex; gap:1px; font-size:10px; line-height:1; }
.badge-cap{ color:var(--green); font-weight:900; }

/* MODAL */
#overlay{ position:fixed; inset:0; background:rgba(0,0,0,.8); z-index:900; display:none; align-items:flex-end; backdrop-filter:blur(6px); -webkit-backdrop-filter:blur(6px); }
#overlay.open{ display:flex; }
#modal{ background:var(--bg); width:100%; max-height:93dvh; border-radius:28px 28px 0 0; display:flex; flex-direction:column; animation:sUp .3s cubic-bezier(.34,1.4,.64,1); padding-bottom:var(--safe-bottom); border:1.5px solid var(--border); border-bottom:none; }
@keyframes sUp{ from{transform:translateY(100%)} to{transform:translateY(0)} }
.modal-handle{ width:40px; height:4px; background:var(--border2); border-radius:2px; margin:10px auto 0; }
.modal-hdr{ display:flex; justify-content:space-between; align-items:center; padding:10px 16px; border-bottom:1px solid var(--border); }
.modal-num{ color:var(--text2); font-size:14px; font-weight:800; }
.modal-hdr-btns{ display:flex; gap:6px; }
.mbtn{ width:36px; height:36px; background:var(--card); border-radius:10px; border:1.5px solid var(--border); color:#fff; font-size:14px; cursor:pointer; display:flex; align-items:center; justify-content:center; font-family:var(--font); }
.mbtn.on{ background:var(--accent); border-color:var(--accent); }
.modal-body{ flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch; overscroll-behavior:contain; }

/* MODAL HERO */
.mhero{ display:flex; flex-direction:column; align-items:center; padding:16px 20px 14px; margin:12px 16px; border-radius:20px; position:relative; }
.shiny-btn{ position:absolute; top:10px; right:10px; width:36px; height:36px; background:rgba(0,0,0,.3); border-radius:10px; border:1.5px solid rgba(255,255,255,.08); display:flex; align-items:center; justify-content:center; font-size:16px; cursor:pointer; }
.shiny-btn.on{ background:rgba(255,215,0,.2); border-color:var(--gold); }
.msprite-wrap{ position:relative; width:130px; height:130px; }
.mimg{ width:130px; height:130px; object-fit:contain; position:absolute; top:0; left:0; transition:opacity .2s; }
.mimg.px{ image-rendering:pixelated; width:110px; height:110px; top:10px; left:10px; }
.mimg.shiny-glow{ filter:drop-shadow(0 0 12px rgba(255,215,0,.7)); }
.mname{ font-size:26px; font-weight:900; margin-top:8px; text-transform:capitalize; letter-spacing:-.3px; }
.mform-name{ font-size:12px; color:var(--text2); font-weight:700; margin-top:2px; text-transform:capitalize; }
.mrar-badge{ display:inline-flex; align-items:center; gap:5px; padding:4px 13px; border-radius:20px; font-size:12px; font-weight:800; margin:8px 0; border:1.5px solid; }
.mtype-row{ display:flex; gap:8px; margin-bottom:12px; }
.mtype-pill{ padding:5px 16px; border-radius:20px; font-size:13px; font-weight:800; color:#fff; }
.mstats-row{ display:flex; gap:22px; align-items:center; }
.mstat{ text-align:center; }
.mstat-val{ font-size:18px; font-weight:900; }
.mstat-lbl{ font-size:10px; color:var(--text2); font-weight:700; margin-top:1px; }
.mstat-div{ width:1px; height:30px; background:var(--border); }

/* QUICK ACTIONS */
.mquick{ display:flex; gap:8px; padding:0 16px 10px; }
.qbtn{ flex:1; display:flex; align-items:center; justify-content:center; gap:6px; padding:10px; border-radius:12px; border:1.5px solid var(--border); background:var(--card); cursor:pointer; font-size:13px; font-weight:800; color:var(--text2); font-family:var(--font); }
.qbtn.fav-on{ background:rgba(233,69,96,.12); border-color:var(--accent); color:var(--accent); }
.qbtn.team-on{ background:rgba(96,165,250,.12); border-color:var(--blue); color:var(--blue); }

/* FORMS */
.forms-sec{ margin:0 16px 10px; }
.forms-label{ font-size:10px; font-weight:900; color:var(--text2); text-transform:uppercase; letter-spacing:.5px; margin-bottom:7px; }
.forms-scroll{ overflow-x:auto; scrollbar-width:none; -webkit-overflow-scrolling:touch; }
.forms-scroll::-webkit-scrollbar{ display:none; }
.forms-inner{ display:flex; gap:7px; padding-bottom:2px; }
.fchip{ display:flex; flex-direction:column; align-items:center; gap:3px; padding:7px 10px; background:var(--card); border-radius:12px; border:1.5px solid var(--border); cursor:pointer; flex-shrink:0; min-width:68px; max-width:80px; }
.fchip.on{ border-color:var(--accent); background:rgba(233,69,96,.1); }
.fchip img{ width:48px; height:48px; object-fit:contain; }
.fchip img.px{ image-rendering:pixelated; width:40px; height:40px; }
.fchip-name{ font-size:9px; font-weight:800; color:var(--text2); text-align:center; text-transform:capitalize; max-width:78px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.fchip.on .fchip-name{ color:var(--accent); }

/* LEGEND */
.mlegend{ margin:0 16px 10px; padding:9px 12px; background:var(--card); border-radius:12px; font-size:11px; color:var(--text2); text-align:center; font-weight:700; line-height:1.9; border:1px solid var(--border); }

/* GEN SECTIONS */
.gen-sec{ margin:0 16px 8px; background:var(--card); border-radius:14px; overflow:hidden; border:1.5px solid var(--border); }
.gen-hdr{ display:flex; justify-content:space-between; align-items:center; padding:12px 14px; cursor:pointer; user-select:none; }
.gen-hdr-l{ display:flex; align-items:center; gap:7px; }
.gen-arrow{ font-size:9px; color:var(--text3); transition:transform .2s; display:inline-block; }
.gen-arrow.open{ transform:rotate(90deg); }
.gen-title{ font-size:13px; font-weight:800; }
.gen-act{ background:rgba(74,222,128,.1); color:var(--green); font-size:10px; font-weight:800; padding:3px 8px; border-radius:9px; border:1px solid rgba(74,222,128,.25); }
.gen-games{ padding:0 10px 10px; gap:5px; flex-direction:column; display:none; }
.gen-games.open{ display:flex; }
.game-row{ background:var(--bg); border-radius:11px; padding:9px 10px; border:1px solid var(--border); }
.game-row.has{ border-color:rgba(74,222,128,.4); background:#0b160b; }
.game-top{ display:flex; align-items:center; gap:7px; }
.game-dot{ width:9px; height:9px; border-radius:50%; flex-shrink:0; }
.game-name{ flex:1; font-size:12px; font-weight:800; color:#c8c8e8; }
.game-opts{ display:flex; gap:4px; }
.obtn{ width:32px; height:32px; border-radius:8px; background:var(--border); border:none; font-size:12px; cursor:pointer; opacity:.28; display:flex; align-items:center; justify-content:center; font-family:var(--font); }
.obtn.on{ opacity:1; }
.obtn.cap.on{ background:#0d2a0d; }
.obtn.shy.on{ background:#2a2000; }
.obtn.box.on{ background:#0d1a2e; }
.obtn.note.on{ background:#1e0d2e; opacity:1; }

/* BALL SELECTOR */
.ball-sec{ margin-top:7px; display:none; }
.ball-sec.open{ display:block; }
.ball-label{ font-size:10px; color:var(--text2); font-weight:800; margin-bottom:5px; text-transform:uppercase; letter-spacing:.3px; }
.ball-grid{ display:flex; flex-wrap:wrap; gap:4px; }
.ball-opt{ display:flex; flex-direction:column; align-items:center; gap:2px; padding:5px 6px; border-radius:9px; background:var(--border); border:1.5px solid transparent; cursor:pointer; min-width:46px; }
.ball-opt.on{ border-color:var(--gold); background:rgba(255,215,0,.1); }
.ball-emoji{ font-size:17px; }
.ball-name{ font-size:8px; color:var(--text2); font-weight:800; text-align:center; }
.notes-wrap{ margin-top:7px; display:none; }
.notes-wrap.open{ display:block; }
.notes-ta{ width:100%; background:var(--border); border:none; border-radius:10px; padding:9px; color:#fff; font-size:14px; font-family:var(--font); font-weight:600; min-height:56px; resize:none; outline:none; }
.notes-ta::placeholder{ color:var(--text3); }
.mspacer{ height:28px; }

/* FAVORITES / TEAM */
.col-header{ padding:10px 16px 6px; flex-shrink:0; }
.col-title{ font-size:22px; font-weight:900; letter-spacing:-.3px; }
.col-sub{ font-size:11px; color:var(--text2); font-weight:700; margin-top:2px; }
.empty-state{ flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:10px; padding:40px; text-align:center; }
.empty-icon{ font-size:52px; opacity:.4; }
.empty-title{ font-size:16px; font-weight:800; color:var(--text2); }
.empty-sub{ font-size:13px; color:var(--text3); font-weight:700; }

/* TEAM SLOTS */
.team-slots{ display:grid; grid-template-columns:repeat(3,1fr); gap:7px; padding:0 16px 10px; flex-shrink:0; }
.tslot{ background:var(--card); border-radius:13px; border:1.5px solid var(--border); display:flex; flex-direction:column; align-items:center; justify-content:center; padding:9px 5px; min-height:92px; cursor:pointer; position:relative; }
.tslot.filled{ border-color:var(--blue); }
.tslot.empty{ border-style:dashed; opacity:.4; }
.tslot img{ width:52px; height:52px; object-fit:contain; }
.tslot-name{ font-size:9px; font-weight:800; text-align:center; margin-top:3px; text-transform:capitalize; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; width:100%; padding:0 4px; }
.tslot-rm{ position:absolute; top:4px; right:4px; font-size:10px; width:18px; height:18px; background:rgba(0,0,0,.5); border-radius:50%; display:flex; align-items:center; justify-content:center; cursor:pointer; }
.tslot-num{ font-size:22px; opacity:.25; }

/* STATS */
.stats-scroll{ flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch; padding:0 16px; padding-bottom:calc(16px + var(--safe-bottom)); overscroll-behavior:contain; }
.stats-hdr{ padding:12px 16px 6px; flex-shrink:0; display:flex; align-items:center; justify-content:space-between; gap:10px; }
.stats-title{ font-size:22px; font-weight:900; letter-spacing:-.3px; flex-shrink:0; }
.game-sel{ background:var(--card); border:1.5px solid var(--border); border-radius:11px; padding:8px 12px; color:var(--text); font-size:13px; font-family:var(--font); font-weight:700; outline:none; -webkit-appearance:none; appearance:none; flex:1; }
.sec-title{ font-size:10px; font-weight:900; text-transform:uppercase; letter-spacing:.7px; color:var(--text2); margin-bottom:8px; padding-top:16px; }
.big-nums{ display:grid; grid-template-columns:repeat(2,1fr); gap:7px; margin-bottom:0; }
.bnum{ background:var(--card); border-radius:13px; padding:13px; border:1.5px solid var(--border); text-align:center; }
.bnum-val{ font-size:30px; font-weight:900; line-height:1; }
.bnum-lbl{ font-size:10px; color:var(--text2); font-weight:700; margin-top:4px; }
.stat-card{ background:var(--card); border-radius:13px; padding:12px; border:1.5px solid var(--border); margin-bottom:0; }
.brow{ display:flex; align-items:center; gap:7px; margin-bottom:5px; }
.brow:last-child{ margin-bottom:0; }
.blabel{ font-size:10px; font-weight:800; width:72px; flex-shrink:0; color:var(--text2); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.bbar-wrap{ flex:1; height:16px; background:var(--border); border-radius:8px; overflow:hidden; }
.bbar{ height:100%; border-radius:8px; transition:width .5s ease; min-width:3px; }
.bval{ font-size:10px; font-weight:900; width:28px; text-align:right; flex-shrink:0; }
