function cardHTML(p){
  const caught=isCap(p.id), shiny=isShiny(p.id), fav=isFav(p.id), team=inTeam(p.id);
  const modern=S.settings.modern;
  const rar=RARITY[p.rarity];
  const types=p.types.map(t=>`<span class="type-tag" style="background:${tc(t)}">${cap(t)}</span>`).join('');
  const topRight=(fav?'❤️':'')+(team?'⚔️':'');
  // Card border/bg based on capture
  const typeClr=tc(p.types[0]);
  let cardStyle='';
  if(caught) cardStyle=`border-color:${typeClr};background:${typeClr}18;`;
  else if(shiny) cardStyle='border-color:#ffd700;';
  else if(fav) cardStyle='border-color:#e9456055;';

  return`<div class="poke-card" style="${cardStyle}" data-id="${p.id}" onclick="openModal(${p.id})">
    <div class="card-top">
      <span class="card-num">#${pad(p.id)}</span>
      <span class="card-rar">${rar.i}</span>
    </div>
    ${topRight?`<div class="card-top-right">${topRight}</div>`:''}
    <img class="poke-img${modern?'':' px'}" src="${spriteOf(p.id,modern,false)}" alt="${p.name}" loading="lazy" onerror="this.style.opacity='.3'">
    <div class="poke-name">${cap(p.name)}</div>
    <div class="poke-types">${types}</div>
    ${caught||shiny?`<div class="card-badges">${caught?'<span class="badge-cap">✓</span>':''}${shiny?'✨':''}</div>`:''}
  </div>`;
}

