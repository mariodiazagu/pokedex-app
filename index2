}

function updateStats(){
  const capC=Object.keys(S.tracking).filter(id=>Object.values(S.tracking[id]).some(g=>g.captured)).length;
  const shyC=Object.keys(S.tracking).filter(id=>Object.values(S.tracking[id]).some(g=>g.shiny)).length;
  document.getElementById('app-stats').textContent=`${capC}/${S.poke.length} capturados · ${shyC}✨`;
}

