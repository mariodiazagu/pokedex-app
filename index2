// ═══════════════════════════════════════
function renderStats(){
  if(S.tab!=='stats') return;
  const gid=document.getElementById('stats-sel').value;
  const total=S.poke.length;
  const capIds=new Set(), shyIds=new Set();
  const neverCap=[], alwaysCap=[];
  const typeCapC={}; TYPES.forEach(t=>{typeCapC[t.id]=0;});
  const rarCapC={}; Object.keys(RARITY).forEach(k=>{rarCapC[k]=0;});
  const ballC={}; BALLS.forEach(b=>{ballC[b.id]=0;});

  S.poke.forEach(p=>{
    const t=S.tracking[p.id];
    let capInSel=false;
    if(gid==='all'){
      const anyCap=t&&Object.values(t).some(g=>g.captured);
      const allCap=t&&GAMES.every(g=>t[g.id]?.captured);
      if(anyCap){
        capIds.add(p.id);
        p.types.forEach(tp=>{if(tp in typeCapC)typeCapC[tp]++;});
        rarCapC[p.rarity]=(rarCapC[p.rarity]||0)+1;
      }
      if(!anyCap) neverCap.push(p);
      if(allCap) alwaysCap.push(p);
      // shiny any game
      if(t&&Object.values(t).some(g=>g.shiny)) shyIds.add(p.id);
      // ball counts
      if(t) Object.values(t).forEach(g=>{if(g?.ball&&g.ball in ballC)ballC[g.ball]++;});
    }else{
      capInSel=!!(t&&t[gid]?.captured);
      if(capInSel){
        capIds.add(p.id);
        p.types.forEach(tp=>{if(tp in typeCapC)typeCapC[tp]++;});
        rarCapC[p.rarity]=(rarCapC[p.rarity]||0)+1;
      }
      if(!capInSel) neverCap.push(p);
      if(t&&t[gid]?.shiny) shyIds.add(p.id);
      if(t&&t[gid]?.ball){const b=t[gid].ball;if(b in ballC)ballC[b]++;}
    }
  });

  const pct=total?Math.round((capIds.size/total)*100):0;
  const typesSorted=TYPES.map(t=>({...t,c:typeCapC[t.id]})).sort((a,b)=>b.c-a.c);
  const maxT=typesSorted[0]?.c||1;
  const topBalls=BALLS.filter(b=>ballC[b.id]>0).sort((a,b)=>ballC[b.id]-ballC[a.id]).slice(0,10);
  const maxBall=topBalls[0]?ballC[topBalls[0].id]:1;
  const perGame=gid==='all'?GAMES.map(g=>({...g,c:Object.values(S.tracking).filter(t=>t[g.id]?.captured).length})).sort((a,b)=>b.c-a.c).slice(0,12):[];
  const maxGame=perGame[0]?.c||1;
  const gameName=gid==='all'?'global':(GAMES.find(g=>g.id===gid)?.name||gid);

  document.getElementById('stats-scroll').innerHTML=`
    <div class="sec-title">📈 Resumen ${gameName}</div>
    <div class="big-nums">
      <div class="bnum"><div class="bnum-val" style="color:var(--green)">${capIds.size}</div><div class="bnum-lbl">Capturados</div></div>
      <div class="bnum"><div class="bnum-val" style="color:var(--gold)">${shyIds.size}</div><div class="bnum-lbl">✨ Shiny</div></div>
      <div class="bnum"><div class="bnum-val" style="color:var(--accent)">${pct}%</div><div class="bnum-lbl">Completado</div></div>
      <div class="bnum"><div class="bnum-val" style="color:var(--text2)">${neverCap.length}</div><div class="bnum-lbl">Sin capturar</div></div>
    </div>

    <div class="sec-title">🎯 Por tipo</div>
    <div class="stat-card">
      ${typesSorted.map(t=>`<div class="brow">
        <div class="blabel">${t.name}</div>
        <div class="bbar-wrap"><div class="bbar" style="width:${Math.round((t.c/maxT)*100)}%;background:${t.color}"></div></div>
        <div class="bval">${t.c}</div>
      </div>`).join('')}
    </div>

    <div class="sec-title">⭐ Por rareza</div>
    <div class="stat-card">
      ${Object.entries(RARITY).map(([k,r])=>{
        const tot=S.poke.filter(p=>p.rarity===k).length;
        const got=rarCapC[k]||0;
        return`<div class="brow">
          <div class="blabel">${r.i} ${r.l}</div>
          <div class="bbar-wrap"><div class="bbar" style="width:${tot?Math.round((got/tot)*100):0}%;background:${r.c}"></div></div>
          <div class="bval">${got}/${tot}</div>
        </div>`;
      }).join('')}
    </div>

    ${perGame.length?`<div class="sec-title">🎮 Top juegos</div>
    <div class="stat-card">
      ${perGame.map(g=>`<div class="brow">
        <div class="blabel">${g.name}</div>
        <div class="bbar-wrap"><div class="bbar" style="width:${Math.round((g.c/maxGame)*100)}%;background:${g.color}"></div></div>
        <div class="bval">${g.c}</div>
      </div>`).join('')}
    </div>`:''}

    ${topBalls.length?`<div class="sec-title">🔴 Pokéballs usadas</div>
    <div class="stat-card">
      ${topBalls.map(b=>`<div class="brow">
        <div class="blabel">${b.e} ${b.n}</div>
        <div class="bbar-wrap"><div class="bbar" style="width:${Math.round((ballC[b.id]/maxBall)*100)}%;background:var(--accent)"></div></div>
        <div class="bval">${ballC[b.id]}</div>
      </div>`).join('')}
    </div>`:''}

    ${neverCap.length?`<div class="sec-title">😔 Nunca capturado (${Math.min(30,neverCap.length)} de ${neverCap.length})</div>
    <div class="prow-list">
      ${neverCap.slice(0,30).map(p=>`<div class="prow" onclick="openModal(${p.id})">
        <img src="${spriteOf(p.id,S.settings.modern,false)}" onerror="this.style.opacity='.2'">
        <div class="prow-info"><div class="prow-name">${cap(p.name)}</div><div class="prow-num">#${pad(p.id)} · ${RARITY[p.rarity].i} ${RARITY[p.rarity].l}</div></div>
        <div class="prow-right" style="color:var(--accent)">✕</div>
      </div>`).join('')}
    </div>`:''}

    ${alwaysCap.length?`<div class="sec-title">🏆 En todos los juegos (${alwaysCap.length})</div>
    <div class="prow-list">
      ${alwaysCap.slice(0,30).map(p=>`<div class="prow" onclick="openModal(${p.id})">
        <img src="${spriteOf(p.id,S.settings.modern,false)}" onerror="this.style.opacity='.2'">
        <div class="prow-info"><div class="prow-name">${cap(p.name)}</div><div class="prow-num">#${pad(p.id)}</div></div>
        <div class="prow-right" style="color:var(--green)">★</div>
      </div>`).join('')}
    </div>`:''}

    <div style="height:20px"></div>
  `;
}

