  </div>`;
}

function refreshRow(pid,gid){
const notesOpen=document.getElementById(`nw-${pid}-${gid}`)?.classList.contains(‘open’);
const ballsOpen=document.getElementById(`bs-${pid}-${gid}`)?.classList.contains(‘open’);
const row=document.getElementById(`gr-${pid}-${gid}`);
const game=GAMES.find(g=>g.id===gid);
if(row&&game){
row.outerHTML=gameRow(pid,game);
if(notesOpen)document.getElementById(`nw-${pid}-${gid}`)?.classList.add(‘open’);
if(ballsOpen)document.getElementById(`bs-${pid}-${gid}`)?.classList.add(‘open’);
}
}

function doTrack(pid,gid,field){
if(!S.tracking[pid]) S.tracking[pid]={};
if(!S.tracking[pid][gid]) S.tracking[pid][gid]=trackDefault();
S.tracking[pid][gid][field]=!S.tracking[pid][gid][field];
LS.saveUser(); refreshRow(pid,gid); updateCard(pid); updateStats();
}

function doBall(pid,gid,ballId){
if(!S.tracking[pid]) S.tracking[pid]={};
if(!S.tracking[pid][gid]) S.tracking[pid][gid]=trackDefault();
S.tracking[pid][gid].ball=S.tracking[pid][gid].ball===ballId?null:ballId;
LS.saveUser(); refreshRow(pid,gid);
}

function doNote(pid,gid,value){
if(!S.tracking[pid]) S.tracking[pid]={};
if(!S.tracking[pid][gid]) S.tracking[pid][gid]=trackDefault();
S.tracking[pid][gid].notes=value;
LS.saveUser(); updateCard(pid);
}

// ═══════════════════════════════════════
//  INIT
// ═══════════════════════════════════════
async function init(){
// Reset error UI
document.getElementById(‘ld-error’).style.display=‘none’;
document.getElementById(‘ld-retry’).style.display=‘none’;
document.getElementById(‘bar-fill’).style.width=‘0%’;
document.getElementById(‘bar-pct’).textContent=‘0%’;

LS.loadUser();
LS.loadForms();
document.getElementById(‘sprite-btn’).textContent=S.settings.modern?‘🎨’:‘👾’;

// Populate stats game selector
const sel=document.getElementById(‘stats-sel’);
// Remove any existing options except first
while(sel.options.length>1) sel.remove(1);
GAMES.forEach(g=>{const o=document.createElement(‘option’);o.value=g.id;o.textContent=g.name;sel.appendChild(o);});

// Try cache first
const cached=LS.loadPoke();
if(cached&&cached.length>=100){
S.poke=cached.map(p=>({…p,rarity:p.rarity||rarOf(p.id)}));
launch(); return;
}

// Fetch from API
const onProg=pct=>{
document.getElementById(‘bar-fill’).style.width=pct+’%’;
document.getElementById(‘bar-pct’).textContent=pct+’%’;
const h=document.getElementById(‘ld-hint’);
if(pct<25) h.textContent=‘🔴 Cargando Gen I…’;
else if(pct<50) h.textContent=‘🟠 Cargando Gen II y III…’;
else if(pct<75) h.textContent=‘🟡 Cargando Gen IV, V y VI…’;
else if(pct<95) h.textContent=‘🟢 Cargando Gen VII, VIII y IX…’;
else h.textContent=‘⚡ Preparando la app…’;
};

try{
S.poke=await fetchAllPokemon(onProg);
if(!S.poke.length) throw new Error(‘Sin datos’);
LS.savePoke(S.poke);
launch();
}catch(err){
console.error(‘Fetch error:’,err);
document.getElementById(‘ld-error’).style.display=‘block’;
document.getElementById(‘ld-error’).textContent=‘Error al cargar. Comprueba tu conexión.’;
document.getElementById(‘ld-retry’).style.display=‘inline-block’;
}
}

function launch(){
document.getElementById(‘loading’).classList.add(‘hidden’);
document.getElementById(‘app’).classList.add(‘visible’);
renderFilters();
renderGrid();
}

init();
</script>

