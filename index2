      </div>`;
    }else{
      sl+=`<div class="tslot empty"><div class="tslot-num">${i+1}</div></div>`;
    }
  }
  document.getElementById('team-slots').innerHTML=sl;
  document.getElementById('team-count').textContent=`${S.team.length}/6 Pokémon`;
  const list=S.poke.filter(p=>S.team.includes(p.id));
  const w=document.getElementById('team-wrap');
  if(!list.length){
    w.innerHTML=`<div class="empty-state"><div class="empty-icon">⚔️</div><div class="empty-title">Equipo vacío</div><div class="empty-sub">Añade hasta 6 Pokémon desde su ficha</div></div>`;
  }else{
    w.innerHTML=`<div class="poke-grid">${list.map(cardHTML).join('')}</div>`;
  }
}

