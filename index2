async function openModal(id){
  S.mId=id; S.mFormIdx=0; S.mModern=S.settings.modern; S.mShiny=false; S.mForms=[];
  const base=S.poke.find(p=>p.id===id); if(!base) return;
  buildModal(base,[]);
  document.getElementById('overlay').classList.add('open');
  document.body.style.overflow='hidden';
  // Load forms async
  const forms=await fetchForms(id);
  if(S.mId===id){ S.mForms=forms; buildModal(base,forms); }
}
function closeModal(){document.getElementById('overlay').classList.remove('open');document.body.style.overflow='';}
function overlayClick(e){if(e.target.id==='overlay')closeModal();}

function buildModal(base,forms){
  const id=base.id;
  const rar=RARITY[base.rarity];
  const fav=isFav(id), team=inTeam(id);
  const typeClr=tc(base.types[0]);
  const caughtC=GAMES.filter(g=>S.tracking?.[id]?.[g.id]?.captured).length;
  const curForm=forms[S.mFormIdx]||null;
  const imgSrc=curForm?formSprite(curForm,S.mModern,S.mShiny):spriteOf(id,S.mModern,S.mShiny);
  const formLabel=curForm?fmtForm(curForm.name,curForm.speciesName):null;

  document.getElementById('modal-num').textContent=`#${pad(id)}`;
  document.getElementById('modal-sprite-btn').textContent=S.mModern?'👾':'🎨';

  const typePills=base.types.map(t=>{
    const ti=TYPES.find(x=>x.id===t);
    return`<span class="mtype-pill" style="background:${tc(t)}">${ti?.name||t}</span>`;
  }).join('');

  const formsHTML=forms.length>1?`<div class="forms-sec">
    <div class="forms-label">Formas (${forms.length})</div>
    <div class="forms-scroll"><div class="forms-inner">
      ${forms.map((f,i)=>{
        const sp=S.mModern?(f.sprites.official||mUrl(f.id)):(f.sprites.front_default||pUrl(f.id));
        return`<div class="fchip${i===S.mFormIdx?' on':''}" onclick="selectForm(${i})">
          <img src="${sp}" alt="${f.name}" class="${S.mModern?'':'px'}" onerror="this.style.opacity='.2'">
          <div class="fchip-name">${fmtForm(f.name,f.speciesName)}</div>
        </div>`;
      }).join('')}
    </div></div>
  </div>`:'';

  const heroStyle=S.mShiny?'rgba(255,215,0,.12)':typeClr+'18';

  const gens=[1,2,3,4,5,6,7,8,9].map(gen=>{
    const gGames=GAMES.filter(g=>g.gen===gen);
    const active=gGames.some(g=>{const d=S.tracking?.[id]?.[g.id];return d&&(d.captured||d.shiny||d.inBox||d.notes||d.ball);});
    return`<div class="gen-sec">
      <div class="gen-hdr" onclick="tGen(${gen})">
        <div class="gen-hdr-l">
          <span class="gen-arrow" id="ga-${gen}">▶</span>
          <span class="gen-title">${GNAMES[gen]}</span>
        </div>
        ${active?'<span class="gen-act">✓ activo</span>':''}
      </div>
      <div class="gen-games" id="gg-${gen}">
        ${gGames.map(g=>gameRow(id,g)).join('')}
      </div>
    </div>`;
  }).join('');

  document.getElementById('modal-body').innerHTML=`
    <div class="mhero" id="mhero" style="background:${heroStyle}">
      <button class="shiny-btn${S.mShiny?' on':''}" id="shiny-btn" onclick="toggleShiny()">✨</button>
      <div class="msprite-wrap">
        <img id="mimg" class="mimg${S.mModern?'':' px'}${S.mShiny?' shiny-glow':''}" src="${imgSrc}" alt="${base.name}" onerror="this.style.opacity='.3'">
      </div>
      <div class="mname">${cap(base.name)}</div>
      ${formLabel&&S.mFormIdx>0?`<div class="mform-name">${formLabel}</div>`:''}
      <div class="mrar-badge" style="background:${rar.bg};border-color:${rar.br};color:${rar.c}">${rar.i} ${rar.l}</div>
      <div class="mtype-row">${typePills}</div>
      <div class="mstats-row">
        <div class="mstat"><div class="mstat-val">${caughtC}/${GAMES.length}</div><div class="mstat-lbl">Juegos</div></div>
        <div class="mstat-div"></div>
        <div class="mstat"><div class="mstat-val">Gen ${base.generation}</div><div class="mstat-lbl">Generación</div></div>
      </div>
    </div>
    <div class="mquick">
      <button class="qbtn${fav?' fav-on':''}" id="qfav" onclick="doFav(${id})">${fav?'❤️':'🤍'} ${fav?'Favorito':'Favoritos'}</button>
      <button class="qbtn${team?' team-on':''}" id="qteam" onclick="doTeam(${id})">${team?'⚔️':'🗡️'} ${team?'En equipo':'Al equipo'}</button>
    </div>
    ${formsHTML}
    <div class="mlegend">✅ Capturado · ✨ Shiny · 📦 En caja · 🔴 Poké Ball · 📝 Notas</div>
    ${gens}
    <div class="mspacer"></div>`;
}

function selectForm(idx){
  S.mFormIdx=idx;
  const base=S.poke.find(p=>p.id===S.mId);
  if(base) buildModal(base,S.mForms);
}

function toggleModalSprite(){
  S.mModern=!S.mModern;
  document.getElementById('modal-sprite-btn').textContent=S.mModern?'👾':'🎨';
  const base=S.poke.find(p=>p.id===S.mId);
  if(base) buildModal(base,S.mForms);
}

function toggleShiny(){
  S.mShiny=!S.mShiny;
  const base=S.poke.find(p=>p.id===S.mId);
  if(base) buildModal(base,S.mForms);
}

function doFav(id){
  toggleFav(id);
  const fav=isFav(id);
