// ═══════════════════════════════════════
//  FETCH POKEMON — uses bulk endpoint (way faster)
// ═══════════════════════════════════════
async function fetchAllPokemon(onProgress){
  // Use the list endpoint + limit to get all names/ids, then batch fetch details
  // Strategy: fetch in batches of 100 concurrent requests
  const TOTAL=1025;
  const all=[];
  const BATCH=100;
  let done=0;

  for(let start=1; start<=TOTAL; start+=BATCH){
    const ids=[];
    for(let i=start; i<start+BATCH && i<=TOTAL; i++) ids.push(i);

    const results=await Promise.allSettled(
      ids.map(id=>
        fetch(`https://pokeapi.co/api/v2/pokemon/${id}`,{cache:'force-cache'})
          .then(r=>{ if(!r.ok) throw new Error(`HTTP ${r.status}`); return r.json(); })
          .then(d=>({
            id:d.id,
            name:d.name,
            types:d.types.map(t=>t.type.name),
            generation:genOf(d.id),
            rarity:rarOf(d.id),
          }))
      )
    );

    results.forEach(r=>{ if(r.status==='fulfilled') all.push(r.value); });
    done+=ids.length;
    onProgress(Math.round((done/TOTAL)*100));
  }
  return all.sort((a,b)=>a.id-b.id);
}

// ═══════════════════════════════════════
//  FETCH FORMS (lazy, per pokemon)
// ═══════════════════════════════════════
async function fetchForms(baseId){
  if(S.formsCache[baseId]) return S.formsCache[baseId];
  const base=S.poke.find(p=>p.id===baseId);
  const fallback=[{id:baseId,name:base?.name||'',speciesName:base?.name||'',types:base?.types||[],
    isDefault:true,sprites:{official:mUrl(baseId),official_shiny:sUrl(baseId),front_default:pUrl(baseId),front_shiny:psUrl(baseId)}}];
  try{
    const specRes=await fetch(`https://pokeapi.co/api/v2/pokemon-species/${baseId}`,{cache:'force-cache'});
    if(!specRes.ok) throw new Error('spec fail');
    const spec=await specRes.json();
    const varieties=spec.varieties||[];
    if(varieties.length<=1){ S.formsCache[baseId]=fallback; LS.saveForms(); return fallback; }

    const forms=await Promise.allSettled(
      varieties.map(v=>
        fetch(v.pokemon.url,{cache:'force-cache'}).then(r=>r.json())
          .then(d=>({
            id:d.id, name:d.name, speciesName:spec.name,
            types:d.types.map(t=>t.type.name),
            isDefault:v.is_default,
            sprites:{
              official:d.sprites?.other?.['official-artwork']?.front_default||null,
              official_shiny:d.sprites?.other?.['official-artwork']?.front_shiny||null,
              front_default:d.sprites?.front_default||null,
              front_shiny:d.sprites?.front_shiny||null,
            }
          }))
      )
    );
    const valid=forms.filter(f=>f.status==='fulfilled').map(f=>f.value)
      .sort((a,b)=>a.isDefault?-1:b.isDefault?1:a.id-b.id);
    const result=valid.length?valid:fallback;
    S.formsCache[baseId]=result;
    LS.saveForms();
    return result;
  }catch(e){
    S.formsCache[baseId]=fallback;
    return fallback;
  }
}

