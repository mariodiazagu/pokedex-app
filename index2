  if(btn){btn.className=`qbtn${fav?' fav-on':''}`;btn.innerHTML=`${fav?'❤️':'🤍'} ${fav?'Favorito':'Favoritos'}`;}
}
function doTeam(id){
  toggleTeam(id);
  const team=inTeam(id);
  const btn=document.getElementById('qteam');
  if(btn){btn.className=`qbtn${team?' team-on':''}`;btn.innerHTML=`${team?'⚔️':'🗡️'} ${team?'En equipo':'Al equipo'}`;}
