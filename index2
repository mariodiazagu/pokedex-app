function toggleTeam(id){
  if(S.team.includes(id)){S.team=S.team.filter(x=>x!==id);}
  else{if(S.team.length>=6){alert('¡Equipo lleno! Máximo 6 Pokémon.');return;}S.team.push(id);}
  LS.saveUser(); updateCard(id);
  if(S.tab==='team') renderTeamPage();
}
function removeFromTeam(id){S.team=S.team.filter(x=>x!==id);LS.saveUser();updateCard(id);renderTeamPage();}
function renderTeamPage(){
  // Slots
  let sl='';
  for(let i=0;i<6;i++){
    const id=S.team[i];
    if(id){
      const p=S.poke.find(x=>x.id===id);
      sl+=`<div class="tslot filled" onclick="openModal(${id})">
        <div class="tslot-rm" onclick="event.stopPropagation();removeFromTeam(${id})">✕</div>
        <img src="${spriteOf(id,S.settings.modern,false)}" alt="" onerror="this.style.opacity='.2'">
