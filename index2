.prow img{ width:40px; height:40px; object-fit:contain; }
.prow-info{ flex:1; min-width:0; }
.prow-name{ font-size:12px; font-weight:800; text-transform:capitalize; }
.prow-num{ font-size:10px; color:var(--text3); font-weight:700; }
.prow-right{ font-size:12px; font-weight:800; flex-shrink:0; }
