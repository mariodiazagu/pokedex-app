function getFiltered(){
  const{q,type,gen,rarity}=S.filters;
  return S.poke.filter(p=>{
    if(q){const lq=q.toLowerCase();if(!p.name.includes(lq)&&!String(p.id).includes(q))return false;}
    if(type&&!p.types.includes(type))return false;
    if(gen&&p.generation!==gen)return false;
    if(rarity&&p.rarity!==rarity)return false;
    return true;
  });
}

function renderGrid(){
  const list=getFiltered();
